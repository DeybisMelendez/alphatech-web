---
import config from '../../config.json';

const navLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Portfolio', href: '#portfolio' },
  { label: 'Equipo', href: '#equipo' },
  { label: 'Precios', href: '#precios' },
  { label: 'FAQ', href: '#faq' },
];

